# Guesty Open API (OAuth2 client-credentials). Token is capped at 5 requests / 24h
# -> the token manager caches it (see src/adapters/tokenCache.ts).
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Market data (public-only, keeps you outside the "common pricing algorithm" line)
WHEELHOUSE_API_KEY=
AIRROI_API_KEY=

# Optional: Redis for the production token cache (falls back to in-memory)
REDIS_URL=

# Hard guardrail defaults
MAX_EFFECTIVE_DISCOUNT=0.35
